# Build output
/bin/
/obj/
/x64/
/Debug/
/Release/
/.vs/
/.claude/

# Local runtime data and extracted assets
/Data/
/**/Data/

# Portable CMake extracted locally by scripts/build.sh from the bundled tarball
# in external/cmake/ (the tarball itself is tracked; the extraction is not).
/.cmake-portable/

# Logs and local state
/Logs/
*.log
imgui.ini
/diagnostics/
*.user
*.suo
*.VC.db
*.VC.opendb
*.ipch
*.pdb
*.ilk

# OS/editor noise
Thumbs.db
Desktop.ini
*.tmp
*.bak
*.old
*~

# Keep runtime shader binaries, ignore stray SPIR-V elsewhere.
*.spv
!shaders/compiled/*.spv
